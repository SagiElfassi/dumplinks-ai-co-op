# Local dev (Docker Compose): use the line below
MONGODB_URI=mongodb://localhost:27017/dumplinks
# Production (Render + Atlas): replace with your Atlas connection string
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dumplinks
JWT_SECRET=change-me-to-a-long-random-string
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
FRONTEND_URL=http://localhost:5173
